#!/bin/bash

# Per-day / per-month / total Claude Code spend, computed from transcript token
# usage × model pricing (the authoritative method — see recompute_cost.py).
# Single source of truth shared with the statusline.
#
# Note: figures only go back as far as Claude Code retains transcripts
# (~30 days). Older months are not shown; for those the raw per-session logs
# in ~/.claude/usage/*.jsonl are the only remaining record (delta-based, less
# accurate).

exec python3 "$HOME/.claude/recompute_cost.py" --report
