{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(which:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(file:*)",
      "Bash(type:*)",
      "Bash(command:*)",
      "Bash(where:*)",
      "Bash(wc:*)",
      "Bash(du:*)",
      "Bash(df:*)",
      "Bash(stat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(cat:*)",
      "Bash(less:*)",
      "Bash(echo:*)",
      "Bash(uname:*)",
      "Bash(whoami:*)",
      "Bash(hostname:*)",
      "Bash(pwd:*)",
      "Bash(date:*)",
      "Bash(sw_vers:*)",
      "Bash(man:*)",
      "Bash(defaults read*)",
      "Bash(az * list*)",
      "Bash(az * show*)",
      "Bash(az * query*)",
      "Bash(az rest --method post --url *CostManagement/query*)",
      "Bash(az rest --method POST --url *CostManagement/query*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git remote*)",
      "Bash(git tag*)",
      "Bash(git stash list*)",
      "Bash(git rev-parse*)",
      "Bash(git add*)",
      "Bash(git fetch*)",
      "Bash(git pull*)",
      "Bash(git switch*)"
    ]
  },
  "model": "claude-opus-4-6",
  "hooks": {
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "DIR_NAME=$(basename \"$PWD\") ; tmux-notify --icon ~/.claude/claude-icon.png \"Claude Code ($DIR_NAME)\" \"Waiting for approval\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "DIR_NAME=$(basename \"$PWD\") ; tmux-notify --icon ~/.claude/claude-icon.png \"Claude Code ($DIR_NAME)\" \"Response ready\""
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high"
}
