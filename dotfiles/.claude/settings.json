{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(which:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(file:*)",
      "Bash(type:*)",
      "Bash(command:*)",
      "Bash(where:*)",
      "Bash(wc:*)",
      "Bash(du:*)",
      "Bash(df:*)",
      "Bash(stat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(cat:*)",
      "Bash(less:*)",
      "Bash(echo:*)",
      "Bash(uname:*)",
      "Bash(whoami:*)",
      "Bash(hostname:*)",
      "Bash(pwd:*)",
      "Bash(date:*)",
      "Bash(sw_vers:*)",
      "Bash(man:*)",
      "Bash(defaults read*)",
      "Bash(az * list*)",
      "Bash(az * show*)",
      "Bash(az * query*)",
      "Bash(az rest --method post --url *CostManagement/query*)",
      "Bash(az rest --method POST --url *CostManagement/query*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git remote*)",
      "Bash(git tag*)",
      "Bash(git stash list*)",
      "Bash(git rev-parse*)",
      "Bash(git add*)",
      "Bash(git fetch*)",
      "Bash(git pull*)",
      "Bash(git switch*)",
      "Bash(kubectl get*)",
      "Bash(kubectl describe*)",
      "Bash(kubectl logs*)",
      "Bash(kubectl config*)",
      "Bash(az rest --method GET*)",
      "Bash(az rest --method get*)",
      "Bash(az account set*)",
      "Bash(az account get-access-token*)",
      "Bash(git ls-tree*)",
      "Bash(git ls-files*)",
      "Bash(git grep*)",
      "Bash(git config*)",
      "Bash(git describe*)",
      "Bash(git merge-base*)",
      "Bash(git version*)",
      "Bash(cargo check*)",
      "Bash(cargo build*)",
      "Bash(cargo fmt*)",
      "Bash(cargo test*)",
      "Bash(cargo clippy*)",
      "Bash(dotnet build*)",
      "Bash(dotnet test*)",
      "Bash(python -m pytest*)",
      "Bash(npx jest*)",
      "Bash(npm run*)",
      "Bash(gh run list*)",
      "Bash(gh run view*)",
      "Bash(gh pr list*)",
      "Bash(gh pr view*)",
      "Bash(gh pr checks*)",
      "Bash(gh api*)",
      "Bash(gh issue list*)",
      "Bash(terraform state list*)",
      "Bash(terraform state show*)",
      "Bash(brew info*)",
      "Bash(brew search*)",
      "Bash(brew list*)",
      "Bash(strings:*)",
      "Bash(tree:*)",
      "Bash(jq:*)",
      "Bash(pip list*)",
      "Bash(pip show*)"
    ]
  },
  "model": "claude-opus-4-6",
  "hooks": {
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "DIR_NAME=$(basename \"$PWD\") ; tmux-notify --icon ~/.claude/claude-icon.png \"Claude Code ($DIR_NAME)\" \"Waiting for approval\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "DIR_NAME=$(basename \"$PWD\") ; tmux-notify --icon ~/.claude/claude-icon.png \"Claude Code ($DIR_NAME)\" \"Response ready\""
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high"
}
