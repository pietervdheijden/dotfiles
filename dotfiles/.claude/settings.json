{
  "model": "claude-opus-4-6",
  "hooks": {
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "DIR_NAME=$(basename \"$PWD\") ; tmux-notify --icon ~/.claude/claude-icon.png \"Claude Code ($DIR_NAME)\" \"Waiting for approval\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "DIR_NAME=$(basename \"$PWD\") ; tmux-notify --icon ~/.claude/claude-icon.png \"Claude Code ($DIR_NAME)\" \"Response ready\""
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "medium",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(which:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(file:*)",
      "Bash(type:*)",
      "Bash(command:*)",
      "Bash(where:*)",
      "Bash(wc:*)",
      "Bash(du:*)",
      "Bash(df:*)",
      "Bash(stat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(cat:*)",
      "Bash(less:*)",
      "Bash(echo:*)",
      "Bash(uname:*)",
      "Bash(whoami:*)",
      "Bash(hostname:*)",
      "Bash(pwd:*)",
      "Bash(date:*)",
      "Bash(sw_vers:*)",
      "Bash(man:*)",
      "Bash(defaults read*)",
      "Bash(az * list*)"
    ]
  }
}
